# .env.example — Variables de entorno del proyecto
# ──────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copiar este archivo a `.env`:  cp .env.example .env
#   2. Completar cada variable con los valores reales de tu entorno local
#   3. NUNCA commitear `.env` — ya está en .gitignore
#   4. Este archivo (.env.example) SÍ debe commitearse (solo tiene placeholders)
# ──────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Activar si se detectó base de datos en /genesis (Q5)
# DATABASE_URL=postgres://user:CHANGE_ME@localhost:5432/dbname
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=myapp_development
# DATABASE_USER=myuser
# DATABASE_PASSWORD=CHANGE_ME

# ── Autenticación ─────────────────────────────────────────────────────────────
# Activar si se detectó auth provider en /genesis (Q5)
# JWT_SECRET=CHANGE_ME_min_32_random_chars
# JWT_EXPIRES_IN=7d
# AUTH_PROVIDER_DOMAIN=your-tenant.auth0.com
# AUTH_PROVIDER_CLIENT_ID=CHANGE_ME
# AUTH_PROVIDER_CLIENT_SECRET=CHANGE_ME
# SESSION_SECRET=CHANGE_ME

# ── Pagos ─────────────────────────────────────────────────────────────────────
# Activar si se detectó procesador de pagos en /genesis (Q5)
# STRIPE_SECRET_KEY=CHANGE_ME
# STRIPE_PUBLISHABLE_KEY=CHANGE_ME
# STRIPE_WEBHOOK_SECRET=CHANGE_ME

# ── Cloud / Storage ───────────────────────────────────────────────────────────
# Activar si se detectó proveedor cloud en /genesis (Q5)
# CLOUD_ACCESS_KEY_ID=CHANGE_ME
# CLOUD_SECRET_ACCESS_KEY=CHANGE_ME
# CLOUD_REGION=us-east-1
# STORAGE_BUCKET=your-bucket-name

# ── Email ─────────────────────────────────────────────────────────────────────
# Activar si se detectó servicio de email en /genesis (Q5)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=no-reply@yourdomain.com
# SMTP_PASSWORD=CHANGE_ME
# EMAIL_API_KEY=CHANGE_ME

# ── Inteligencia Artificial ───────────────────────────────────────────────────
# Activar si se detectó integración AI en /genesis (Q5)
# AI_API_KEY=CHANGE_ME
# AI_MODEL=claude-sonnet-4-6

# ── Monitoreo / Observabilidad ────────────────────────────────────────────────
# SENTRY_DSN=CHANGE_ME
# LOG_LEVEL=info

# ── VCS / Integraciones externas ─────────────────────────────────────────────
# VCS_TOKEN=CHANGE_ME
# WEBHOOK_SECRET=CHANGE_ME
